@using Core.DTOs.DeveloperDtos
@using Core.Enums
@using Core.Helpers
@model PaginatedList<DeveloperTaskListDto>
@{
    ViewData["Title"] = "Task'larım";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Üzerimdeki Task'lar</h4>
                    <div>
                        <span class="badge badge-warning mr-1">
                            Devam Eden: @Model.Count(t => t.Status == DevelopmentStatus.InProgress)
                        </span>
                        <span class="badge badge-secondary">
                            Beklemede: @Model.Count(t => t.Status == DevelopmentStatus.OnHold)
                        </span>
                    </div>
                </div>

                <div class="card-body">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @TempData["ErrorMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }

                    <form asp-action="Index" method="get" class="mb-4">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <input type="text"
                                       name="search"
                                       class="form-control"
                                       placeholder="Task başlığı ile ara..."
                                       value="@ViewBag.Search" />
                            </div>
                            <div class="col-md-3">
                                <select name="status" class="form-control">
                                    <option value="">Tüm Durumlar</option>
                                    @foreach (SelectListItem item in ViewBag.StatusList)
                                    {
                                        <option value="@item.Value"
                                                selected="@(item.Selected ? "selected" : null)">
                                            @item.Text
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-info w-100">Filtrele</button>
                            </div>
                            <div class="col-md-2">
                                <a asp-action="Index" class="btn btn-secondary w-100">Temizle</a>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Başlık</th>
                                    <th>Açan</th>
                                    <th>Analist</th>
                                    <th>Zorluk</th>
                                    <th>Öncelik</th>
                                    <th>Durum</th>
                                    <th>Bitiş</th>
                                    <th>Atandı</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="10" class="text-center text-muted py-4">
                                            Üzerinizde task bulunmuyor.
                                        </td>
                                    </tr>
                                }
                                @foreach (var task in Model)
                                {
                                    <tr>
                                        <td>@task.Id</td>
                                        <td>
                                            <a asp-action="Detail"
                                               asp-route-id="@task.DevelopmentId"
                                               class="text-dark font-weight-bold">
                                                @task.Title
                                            </a>
                                        </td>
                                        <td>@task.OpenerName</td>
                                        <td>@task.AnalystName</td>
                                        <td>
                                            <span class="badge badge-info">@task.DifficultyName</span>
                                        </td>
                                        <td>
                                            @{
                                                var priorityClass = task.Priority switch
                                                {
                                                    TaskPriority.Low => "badge-secondary",
                                                    TaskPriority.Medium => "badge-primary",
                                                    TaskPriority.High => "badge-warning",
                                                    TaskPriority.Critical => "badge-danger",
                                                    _ => "badge-secondary"
                                                };
                                            }
                                            <span class="badge @priorityClass">@task.PriorityName</span>
                                        </td>
                                        <td>
                                            @{
                                                var statusClass = task.Status switch
                                                {
                                                    DevelopmentStatus.InProgress => "badge-warning",
                                                    DevelopmentStatus.OnHold => "badge-secondary",
                                                    DevelopmentStatus.Done => "badge-success",
                                                    DevelopmentStatus.Cancelled => "badge-danger",
                                                    _ => "badge-secondary"
                                                };
                                            }
                                        <span class="badge @statusClass">@task.StatusName</span>
                                    </td>
                                    <td>
                                        @(task.DueDate.HasValue
                                                                                ? task.DueDate.Value.ToString("dd.MM.yyyy")
                                                                                : "-")
                                    </td>
                                    <td>@task.AssignedAt.ToString("dd.MM.yyyy")</td>
                                    <td class="text-center">
                                        <a asp-action="Detail"
                                           asp-route-id="@task.DevelopmentId"
                                           class="btn btn-info btn-xs"
                                           title="Detay">
                                            <i class="fa fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-pageIndex="@(Model.PageIndex - 1)"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-status="@ViewBag.Status">&laquo;</a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                        <a class="page-link"
                                           asp-action="Index"
                                           asp-route-pageIndex="@i"
                                           asp-route-search="@ViewBag.Search"
                                           asp-route-status="@ViewBag.Status">@i</a>
                                    </li>
                                }
                                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-pageIndex="@(Model.PageIndex + 1)"
                                       asp-route-search="@ViewBag.Search"
                                       asp-route-status="@ViewBag.Status">&raquo;</a>
                                </li>
                            </ul>
                        </nav>
                        <p class="text-center text-muted small">
                            Toplam @Model.TotalCount kayıt — Sayfa @Model.PageIndex / @Model.TotalPages
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>