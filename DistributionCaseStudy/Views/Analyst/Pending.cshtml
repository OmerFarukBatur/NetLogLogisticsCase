@using Core.DTOs.AnalystDtos
@using Core.Helpers
@model PaginatedList<TaskPendingListDto>
@{
    ViewData["Title"] = "Bekleyen Task'lar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Analiz Bekleyen Task'lar</h4>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="fa fa-arrow-left"></i> Task'larıma Dön
                    </a>
                </div>

                <div class="card-body">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            @TempData["ErrorMessage"]
                            <button type="button" class="close" data-dismiss="alert">&times;</button>
                        </div>
                    }

                    <form asp-action="Pending" method="get" class="mb-4">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-7">
                                <input type="text"
                                       name="search"
                                       class="form-control"
                                       placeholder="Başlık veya açıklama ile ara..."
                                       value="@ViewBag.Search" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-info w-100">Ara</button>
                            </div>
                            <div class="col-md-2">
                                <a asp-action="Pending" class="btn btn-secondary w-100">Temizle</a>
                            </div>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Başlık</th>
                                    <th>Açıklama</th>
                                    <th>Açan</th>
                                    <th>Bitiş</th>
                                    <th>Açılma</th>
                                    <th class="text-center">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">
                                            Analiz bekleyen task bulunmuyor.
                                        </td>
                                    </tr>
                                }
                                @foreach (var task in Model)
                                {
                                    <tr>
                                        <td>@task.Id</td>
                                        <td><strong>@task.Title</strong></td>
                                        <td>
                                            @(task.Description?.Length > 80
                                                                                    ? task.Description.Substring(0, 80) + "..."
                                                                                    : task.Description)
                                                                                                   </td>
                                                                                                   <td>@task.OpenerName</td>
                                                                                                   <td>
                                            @(task.DueDate.HasValue
                                                                                    ? task.DueDate.Value.ToString("dd.MM.yyyy")
                                                                                    : "-")
                                    </td>
                                    <td>@task.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    <td class="text-center">
                                        <form asp-action="TakeTask" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="taskId" value="@task.Id" />
                                            <button type="submit"
                                                    class="btn btn-primary btn-xs"
                                                    title="Analiz Et"
                                                    onclick="return confirm('Bu task\'ı analiz için üstlenmek istiyor musunuz?')">
                                                <i class="fa fa-search"></i> Analiz Et
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Pending"
                                       asp-route-pageIndex="@(Model.PageIndex - 1)"
                                       asp-route-search="@ViewBag.Search">&laquo;</a>
                                </li>
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                        <a class="page-link"
                                           asp-action="Pending"
                                           asp-route-pageIndex="@i"
                                           asp-route-search="@ViewBag.Search">@i</a>
                                    </li>
                                }
                                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                    <a class="page-link"
                                       asp-action="Pending"
                                       asp-route-pageIndex="@(Model.PageIndex + 1)"
                                       asp-route-search="@ViewBag.Search">&raquo;</a>
                                </li>
                            </ul>
                        </nav>
                        <p class="text-center text-muted small">
                            Toplam @Model.TotalCount kayıt — Sayfa @Model.PageIndex / @Model.TotalPages
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>