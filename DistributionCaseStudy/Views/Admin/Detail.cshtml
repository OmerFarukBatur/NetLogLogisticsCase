@using Core.DTOs.AdminDtos
@using Core.Enums
@model UserDetailDto
@{
    ViewData["Title"] = "Kullanıcı Detay";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card" style="height:700px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Kullanıcı Detay</h4>
                    <div>
                        <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                            <i class="fa fa-edit"></i> Güncelle
                        </a>
                        <a asp-action="Index" class="btn btn-secondary btn-sm ml-1">
                            <i class="fa fa-arrow-left"></i> Geri
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th class="text-muted" width="40%">Ad Soyad</th>
                                    <td><strong>@Model.FullName</strong></td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Email</th>
                                    <td>@Model.Email</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Rol</th>
                                    <td>
                                        <span class="badge badge-primary">@Model.RoleName</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th class="text-muted" width="40%">Personel Durumu</th>
                                    <td>
                                        @{
                                            var statusClass = Model.Status switch
                                            {
                                                PersonnelStatus.Active => "badge-success",
                                                PersonnelStatus.Inactive => "badge-secondary",
                                                PersonnelStatus.OnLeave => "badge-warning",
                                                PersonnelStatus.Sick => "badge-info",
                                                PersonnelStatus.Terminated => "badge-danger",
                                                _ => "badge-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass">@Model.StatusName</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Hesap Durumu</th>
                                    <td>
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge badge-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Pasif</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Eklenme</th>
                                    <td>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Güncelleme</th>
                                    <td>@(Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>