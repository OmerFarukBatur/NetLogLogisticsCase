@using Core.DTOs.AdminDtos
@model UserCreateDto
@{
    ViewData["Title"] = "Yeni Kullanıcı";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card" style="height:700px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Yeni Kullanıcı Ekle</h4>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="fa fa-arrow-left"></i> Geri
                    </a>
                </div>
                <div class="card-body">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                    }

                    <form asp-action="Create" method="post" asp-antiforgery="true">

                        <h6 class="text-primary mb-3">Hesap Bilgileri</h6>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Email <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="email" class="form-control" asp-for="Email" placeholder="Email adresi" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Şifre <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="password" class="form-control" asp-for="Password" placeholder="Şifre" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-4">
                            <label class="col-lg-3 col-form-label">
                                Rol <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <select class="form-control" asp-for="RoleId" asp-items="ViewBag.RoleList">
                                    <option value="">-- Rol Seçiniz --</option>
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr />
                        <h6 class="text-primary mb-3">Personel Bilgileri</h6>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Ad <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="text" class="form-control" asp-for="FirstName" placeholder="Ad" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Soyad <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="text" class="form-control" asp-for="LastName" placeholder="Soyad" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-lg-9 ml-auto">
                                <button type="submit" class="btn btn-primary">Kaydet</button>
                                <a asp-action="Index" class="btn btn-secondary ml-2">İptal</a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
