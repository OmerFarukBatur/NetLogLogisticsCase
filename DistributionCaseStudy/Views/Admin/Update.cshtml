@using Core.DTOs.AdminDtos
@model UserUpdateDto
@{
    ViewData["Title"] = "Kullanıcı Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card" style="height:700px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Kullanıcı Güncelle</h4>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="fa fa-arrow-left"></i> Geri
                    </a>
                </div>
                <div class="card-body">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                    }

                    <form asp-action="Update" method="post" asp-antiforgery="true">

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PersonnelId" />

                        <h6 class="text-primary mb-3">Hesap Bilgileri</h6>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Email <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="email" class="form-control" asp-for="Email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Rol <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <select class="form-control" asp-for="RoleId" asp-items="ViewBag.RoleList">
                                    <option value="">-- Rol Seçiniz --</option>
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-4">
                            <label class="col-lg-3 col-form-label">Hesap Durumu</label>
                            <div class="col-lg-9">
                                <div class="custom-control custom-switch mt-2">
                                    <input type="checkbox"
                                           class="custom-control-input"
                                           asp-for="IsActive"
                                           id="isActiveSwitch" />
                                    <label class="custom-control-label" for="isActiveSwitch">
                                        Aktif
                                    </label>
                                </div>
                            </div>
                        </div>

                        <hr />
                        <h6 class="text-primary mb-3">Personel Bilgileri</h6>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Ad <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="text" class="form-control" asp-for="FirstName" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-3">
                            <label class="col-lg-3 col-form-label">
                                Soyad <span class="text-danger">*</span>
                            </label>
                            <div class="col-lg-9">
                                <input type="text" class="form-control" asp-for="LastName" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group row mb-4">
                            <label class="col-lg-3 col-form-label">Personel Durumu</label>
                            <div class="col-lg-9">
                                <select class="form-control" asp-for="Status" asp-items="ViewBag.StatusList">
                                </select>
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-lg-9 ml-auto">
                                <button type="submit" class="btn btn-primary">Güncelle</button>
                                <a asp-action="Index" class="btn btn-secondary ml-2">İptal</a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}