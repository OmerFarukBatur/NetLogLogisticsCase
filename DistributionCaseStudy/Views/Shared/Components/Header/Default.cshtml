@model HeaderViewModel

<div class="header">
    <div class="header-content clearfix">

        <div class="nav-control">
            <div class="hamburger">
                <span class="toggle-icon"><i class="icon-menu"></i></span>
            </div>
        </div>

        <div class="header-right">
            <ul class="clearfix">
                <li class="icons dropdown">
                    <div class="user-img c-pointer position-relative" data-toggle="dropdown">
                        <span class="activity active"></span>
                        <img src="~/TemplasteDocs/images/user/1.png"
                             height="40" width="40" alt="Profil" />
                    </div>

                    <div class="drop-down dropdown-profile animated fadeIn dropdown-menu">
                        <div class="dropdown-content-body">

                            <div class="px-3 py-2 border-bottom mb-1">
                                <p class="mb-0 font-weight-bold text-dark">@Model.FullName</p>
                                <small class="text-muted">@Model.RoleName</small>
                            </div>

                            <ul>
                                <li>
                                    <a asp-controller="Auth" asp-action="PwdReset">
                                        <i class="icon-lock"></i>
                                        <span>Şifre Sıfırla</span>
                                    </a>
                                </li>
                                <li>
                                    <form asp-controller="Auth"
                                          asp-action="Logout"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-link p-0"
                                                style="color: inherit; text-decoration: none;">
                                            <i class="icon-key"></i>
                                            <span>Çıkış Yap</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>

                        </div>
                    </div>
                </li>
            </ul>
        </div>

    </div>
</div>
