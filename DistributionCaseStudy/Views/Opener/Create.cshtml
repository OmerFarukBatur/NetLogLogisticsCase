@using Core.DTOs.OpenerDtos
@model TaskCreateDto
@{
    ViewData["Title"] = "Yeni Task";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card" style="height:700px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">Yeni Task Oluştur</h4>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="fa fa-arrow-left"></i> Geri
                    </a>
                </div>
                <div class="card-body">

                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                    }

                    <form asp-action="Create" method="post" asp-antiforgery="true">

                        <div class="form-group mb-3">
                            <label>Başlık <span class="text-danger">*</span></label>
                            <input type="text"
                                   class="form-control"
                                   asp-for="Title"
                                   placeholder="Task başlığını giriniz" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label>Açıklama <span class="text-danger">*</span></label>
                            <textarea class="form-control"
                                      asp-for="Description"
                                      rows="5"
                                      placeholder="Task'ın ne olduğunu detaylıca açıklayınız"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label>Beklentileriniz</label>
                            <textarea class="form-control"
                                      asp-for="ExpectationNotes"
                                      rows="3"
                                      placeholder="Bu task'tan beklentilerinizi belirtiniz (opsiyonel)"></textarea>
                            <span asp-validation-for="ExpectationNotes" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label>Bitiş Tarihi</label>
                            <input type="date"
                                   class="form-control"
                                   asp-for="DueDate"
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">Oluştur</button>
                            <a asp-action="Index" class="btn btn-secondary ml-2">İptal</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}