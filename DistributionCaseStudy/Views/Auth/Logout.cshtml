@using Core.DTOs.AuthDtos
@model PasswordResetDto
@{
    ViewData["Title"] = "Şifre Sıfırla";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">

                    <div class="row page-titles mx-0" style="background-color:white;">
                        <div class="col p-md-0">
                            <h4 class="text-center">Şifre Sıfırla</h4>
                        </div>
                    </div>

                    <div class="form-validation" style="padding-top:100px;">
                        <form class="form-valide"
                              asp-controller="Auth"
                              asp-action="PwdReset"
                              method="post"
                              asp-antiforgery="true">

                            @if (ViewBag.ErrorMessage != null)
                            {
                                <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                            }

                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                            }

                            <div class="form-group row mb-3">
                                <label class="col-lg-4 col-form-label">
                                    Şifre <span class="text-danger">*</span>
                                </label>
                                <div class="col-lg-6">
                                    <input type="password"
                                           class="form-control"
                                           asp-for="Password"
                                           placeholder="Şifre" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-lg-4 col-form-label">
                                    Şifre Tekrarı <span class="text-danger">*</span>
                                </label>
                                <div class="col-lg-6">
                                    <input type="password"
                                           class="form-control"
                                           asp-for="PasswordConfirm"
                                           placeholder="Şifre Tekrar" />
                                    <span asp-validation-for="PasswordConfirm" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-lg-8 ml-auto">
                                    <button type="submit" class="btn btn-primary">Gönder</button>
                                </div>
                            </div>

                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}